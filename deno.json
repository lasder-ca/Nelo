{
  "name": "nelo",
  "version": "0.0.0",
  "exports": {
    ".": "./mod.ts",
    "./lifetime": "./src/lifetime/mod.ts"
  },
  "tasks": {
    "check": "deno check mod.ts examples/*/mod.ts scripts/*.ts",
    "test": "deno test",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "build": "npm run build"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "nelo": "./mod.ts",
    "@latteworkspace/nelo": "./mod.ts"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  },
  "fmt": {
    "include": [
      "*.ts",
      "*.json",
      "src/**/*.ts",
      "examples/**/*.ts",
      "scripts/**/*.ts",
      "README.md",
      "docs/**/*.md"
    ],
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "include": ["*.ts", "src/**/*.ts", "examples/**/*.ts", "scripts/**/*.ts"]
  }
}
