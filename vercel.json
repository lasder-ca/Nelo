{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix website install",
  "buildCommand": "npm --prefix website run build",
  "outputDirectory": "website/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/brand/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
