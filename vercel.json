{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix website install --no-audit --no-fund",
  "buildCommand": "npm --prefix website run build",
  "outputDirectory": "website/out",
  "cleanUrls": true,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/brand/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
