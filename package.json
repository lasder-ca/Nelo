{
  "name": "nelo",
  "version": "0.1.0-alpha.1",
  "private": true,
  "type": "module",
  "description": "A request-ownership runtime and Web Standards framework for TypeScript.",
  "exports": {
    ".": {
      "types": "./dist/mod.d.ts",
      "import": "./dist/mod.js"
    },
    "./lifetime": {
      "types": "./dist/src/lifetime/mod.d.ts",
      "import": "./dist/src/lifetime/mod.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "format": "deno fmt --check",
    "format:write": "deno fmt",
    "lint": "deno lint",
    "typecheck": "deno check mod.ts examples/*/mod.ts",
    "test": "deno test",
    "build": "tsc -p tsconfig.build.json && deno run --allow-read=dist --allow-write=dist scripts/rewrite-declarations.ts",
    "check:package": "tsc --ignoreConfig --noEmit --strict --noUncheckedIndexedAccess --target ES2022 --module NodeNext --moduleResolution NodeNext --lib ES2022,DOM,ESNext.Disposable scripts/package-smoke.ts",
    "pack:dry-run": "npm pack --dry-run"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
